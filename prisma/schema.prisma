generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String         @id @default(cuid())
  name            String?
  email           String?        @unique
  image           String?
  role            UserRole       @default(TRADER)
  createdAt       DateTime       @default(now())
  storeSlug       String?        @unique
  storeName       String?        @unique
  description     String?
  facebookLink    String?
  hasReturnPolicy String?
  instaLink       String?
  phone           String?
  shippingPrice   Float?
  shippingType    String?
  telegram        String?
  active          Boolean?       @default(true)
  theme           String         @default("MODERN")
  Notification    Notification[]
  orders          Order[]
  Product         Product[]
  stores          StoreUser[]

  Supplier Supplier[]
  coupons  Coupon[]

  UserSubscription    UserSubscription?
  subscriptionHistory SubscriptionHistory[]
  merchant            Merchant?             @relation("UserMerchant")
  traderOrders        OrderFromTrader[]     @relation("TraderOrderRelation")
  traderProfit        TraderProfit?
  invitesSent         Invite[]              @relation("InviteOwner")
  couponUsages        CouponUsage[]
  ProfitWithdrawal    ProfitWithdrawal[]

  paymentLinks PaymentLink[]
}

model Supplier {
  id              String     @id @default(cuid())
  userId          String     @unique
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String?
  image           String?
  Header          String?
  description     String?
  facebookLink    String?
  instaLink       String?
  telegram        String?
  methodPayment   String?
  hasReturnPolicy String?
  shippingPrice   Float?
  shippingType    String?
  theme           ThemeStore @default(MODERN)
  active          Boolean    @default(true)
  address         String?
  paymentInfo     String?
  rating          Float?     @default(0)
  commission      Float?     @default(0)
  phone           String?
  stores          Store[]
  products        Product[]
  orders          Order[]

  ProductPricing ProductPricing[]
  traderOrders   OrderFromTrader[] @relation("SupplierOrderRelation")
}

model Store {
  id              String         @id @default(cuid())
  name            String?
  subLink         String?        @unique
  shippingPrice   Float?
  shippingType    String?
  hasReturnPolicy String?
  image           String?
  Header          String?
  facebookLink    String?
  instaLink       String?
  phone           String?
  active          Boolean?
  methodPayment   String?
  telegram        String?
  description     String?
  createdAt       DateTime       @default(now())
  products        Product[]
  users           StoreUser[]
  category        String?
  facebookPixel   String?
  instagramPixel  String?
  tiktokPixel     String?
  googlePixel     String?
  snapPixel       String?
  Order           Order[]
  theme           String         @default("MODERN")
  Notification    Notification[]
  invites         Invite[]
  Supplier        Supplier[]

  coupons     Coupon[]
  balances    Balance[]
  ledgers     Ledger[]
  withdrawals Withdrawal[]
  template    StoreTemplate?

  paymentLinks PaymentLink[]
}

model StoreUser {
  id      String @id @default(cuid())
  storeId String
  userId  String

  role    StoreUserRole @default(OWNER)
  isOwner Boolean       @default(false)

  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
}

enum StoreUserRole {
  OWNER
  ADMIN
  MEMBER
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  storeId   String
  ownerId   String
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  store Store @relation(fields: [storeId], references: [id])
  owner User  @relation("InviteOwner", fields: [ownerId], references: [id])
}

model Product {
  id                   String                @id @default(cuid())
  name                 String
  description          String?
  price                Float
  quantity             Int                   @default(0)
  image                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  userId               String?
  category             String?
  discount             Float?
  hasReturnPolicy      String?
  shippingPrice        Float?
  shippingType         String?
  storeId              String?
  Notification         Notification[]
  OrderItem            OrderItem[]
  store                Store?                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  images               ProductImage[]
  sizes                ProductSize[]
  unlimited            Boolean               @default(false)
  isDigital            Boolean               @default(false)
  colors               ProductColor[]
  isFromSupplier       Boolean               @default(false)
  supplierId           String?
  Supplier             Supplier[]
  pricingDetails       ProductPricing?
  orderFromTraderItems OrderFromTraderItem[]
  subInfo              ProductSubInfo?
  coupons              Coupon[]
}

model ProductPricing {
  id             String   @id @default(cuid())
  productId      String   @unique
  supplierId     String?
  wholesalePrice Float
  minPrice       Float
  maxPrice       Float
  minQuantity    Int?
  createdAt      DateTime @default(now())

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSubInfo {
  id              String  @id @default(cuid())
  telegram        String?
  whatsapp        String?
  facebookLink    String?
  instaLink       String?
  videoLink       String?
  returnPolicy    String?
  shippingDetails String?
  productId       String  @unique
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSize {
  id        String  @id @default(cuid())
  size      String
  stock     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductColor {
  id        String  @id @default(cuid())
  color     String
  hex       String?
  stock     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id           String         @id @default(cuid())
  createdAt    DateTime       @default(now())
  status       OrderStatus    @default(PENDING)
  total        Float          @default(0)
  userId       String?
  storeId      String?
  email        String?
  fullName     String?
  location     String?
  phone        String?
  Notification Notification[]
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  store        Store?         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  items OrderItem[]

  Supplier Supplier[]

  paymentOrder PaymentOrder?
  couponId     String?
  coupon       Coupon?       @relation(fields: [couponId], references: [id])

  discount Float? @default(0)

  finalTotal   Float         @default(0)
  couponUsages CouponUsage[]
  ledgers      Ledger[]

  paymentMethod String?
}

model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  price     Float
  orderId   String
  color     String?
  size      String?
  productId String?
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
}

model PaymentOrder {
  id            String   @id @default(cuid())
  orderId       String   @unique
  cartId        String   @unique
  tranRef       String?
  amount        Float
  currency      String   @default("IQD")
  status        String
  respCode      String?
  respMessage   String?
  token         String?
  customerEmail String?
  signature     String?
  createdAt     DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

model Payment {
  id            String   @id @default(cuid())
  cartId        String   @unique
  tranRef       String?
  amount        Float
  currency      String   @default("IQD")
  status        String
  respCode      String?
  respMessage   String?
  token         String?
  customerEmail String?
  signature     String?
  createdAt     DateTime @default(now())
  userId        String
  planId        String
  isActive      Boolean  @default(false)

  @@index([cartId])
}

model Visitor {
  id         String   @id @default(cuid())
  visitorId  String
  ip         String
  userAgent  String?
  createdAt  DateTime @default(now())
  storeName  String?
  path       String?
  pageType   String?
  entityType String?
  entityId   String?
  entityName String?
  referrer   String?

  @@index([storeName, createdAt])
  @@index([storeName, pageType, createdAt])
  @@index([storeName, entityType, entityId])
  @@index([visitorId, createdAt])
}

//
model Notification {
  id                String           @id @default(cuid())
  userId            String?
  storeId           String?
  message           String
  url               String?
  isRead            Boolean          @default(false)
  type              String?
  createdAt         DateTime         @default(now())
  orderId           String?
  productId         String?
  orderFromTraderId String?
  orderFromTrader   OrderFromTrader? @relation("TraderOrderNotifications", fields: [orderFromTraderId], references: [id])

  order   Order?   @relation(fields: [orderId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

enum UserRole {
  GUEST
  SUPPLIER
  DROPSHIPPER
  TRADER
  A
}

enum ThemeStore {
  NORMAL
  MODERN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  PAYMENT_FAILED
  PAYMENT_PENDING
}

enum TypePlan {
  NORMAL
  MODERN
  PENDINGROFESSIONAL
}

model SubscriptionPlan {
  id               String   @id @default(cuid())
  name             String
  type             String
  price            Float
  durationDays     Int
  maxProducts      Int?
  maxTemplates     Int?
  templateCategory String?
  maxStores        Int?
  maxSuppliers     Int?
  features         Json?
  description      String?
  createdAt        DateTime @default(now())

  subscriptions UserSubscription[]
  history       SubscriptionHistory[]
}

model UserSubscription {
  id     String @id @default(cuid())
  userId String @unique
  planId String

  startDate DateTime @default(now())
  endDate   DateTime
  isActive  Boolean  @default(true)

  canceledAt DateTime?
  autoRenew  Boolean   @default(false)

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  history SubscriptionHistory[]
}

model SubscriptionHistory {
  id String @id @default(cuid())

  userId         String
  planId         String
  subscriptionId String?

  startDate DateTime
  endDate   DateTime

  price     Float
  paymentId String?
  status    SubscriptionStatus

  createdAt DateTime @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planId])
  @@index([subscriptionId])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  PENDING
}

model Merchant {
  id     String  @id @default(cuid())
  userId String? @unique
  user   User?   @relation("UserMerchant", fields: [userId], references: [id], onDelete: Cascade)

  username  String    @unique
  password  String
  token     String?
  tokenExp  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model OrderFromTrader {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  status    OrderStatus @default(PENDING)
  total     Float       @default(0)

  orderId String? @unique

  traderId   String?
  supplierId String?

  fullName String?
  location String?
  phone    String?

  trader   User?     @relation("TraderOrderRelation", fields: [traderId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation("SupplierOrderRelation", fields: [supplierId], references: [id], onDelete: Cascade)

  items        OrderFromTraderItem[]
  paymentOrder OrderFromTraderPayment?

  Notification Notification[] @relation("TraderOrderNotifications")
}

model OrderFromTraderItem {
  id             String  @id @default(cuid())
  quantity       Int     @default(1)
  price          Float
  wholesalePrice Float?
  traderProfit   Float?
  supplierProfit Float?
  orderId        String
  color          String?
  size           String?
  productId      String?

  order   OrderFromTrader @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
}

model OrderFromTraderPayment {
  id            String   @id @default(cuid())
  orderId       String   @unique
  cartId        String   @unique
  tranRef       String?
  amount        Float
  currency      String   @default("IQD")
  status        String
  respCode      String?
  respMessage   String?
  token         String?
  customerEmail String?
  signature     String?
  createdAt     DateTime @default(now())

  order OrderFromTrader @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

model TraderProfit {
  id String @id @default(cuid())

  traderId String @unique
  trader   User   @relation(fields: [traderId], references: [id], onDelete: Cascade)

  amount    Float
  remaining Float

  withdraw  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProfitWithdrawal {
  id        String           @id @default(cuid())
  traderId  String
  amount    Float
  status    WithdrawalStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  trader User @relation(fields: [traderId], references: [id], onDelete: Cascade)
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Coupon {
  id String @id @default(cuid())

  code String @unique

  scope CouponScope @default(GLOBAL)

  type CouponType

  value Float

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  minOrder    Float?
  maxDiscount Float?
  maxUsage    Int?
  perUser     Int?

  startsAt  DateTime? @default(now())
  expiresAt DateTime?

  isActive Boolean @default(true)

  usedCount Int @default(0)

  usages CouponUsage[]

  createdAt DateTime @default(now())
  orders    Order[]
}

enum CouponScope {
  GLOBAL
  STORE
  PRODUCT
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

model CouponUsage {
  id String @id @default(cuid())

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  usedAt DateTime @default(now())

  @@index([couponId])
  @@index([userId])
}

model Balance {
  id String @id @default(cuid())

  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  available Float @default(0)
  pending   Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ledger {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type LedgerType

  amount Float

  balanceAfter Float?

  note String?

  createdAt DateTime @default(now())
}

enum LedgerType {
  PAYMENT_RECEIVED
  ORDER_PROFIT
  PLATFORM_FEE
  WITHDRAW_REQUEST
  WITHDRAW_APPROVED
  REFUND
}

model Withdrawal {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  amount Float

  status WithdrawalStatus @default(PENDING)

  method String?
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreTemplate {
  id      String @id @default(cuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  tagline             String?
  heroButtonText      String?
  heroSecondaryButton String?
  aboutText           String?
  storeDescription    String?

  ctaTitle  String?
  ctaDesc   String?
  ctaButton String?

  contactEmail   String?
  contactWebsite String?
  whatsappNumber String?
  contactItems   Json?

  headingFont String @default("IBM Plex Sans Arabic")
  bodyFont    String @default("IBM Plex Sans Arabic")

  selectedPreset  Int     @default(0)
  useCustomColors Boolean @default(false)
  colorPrimary    String?
  colorAccent     String?
  colorBg         String?
  colorText       String?

  categoryDisplayMode String @default("icons")

  announcementBar Json?

  sectionsConfig Json?

  isDraft     Boolean   @default(true)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services         TemplateService[]
  works            TemplateWork[]
  testimonials     TemplateTestimonial[]
  bannerImages     TemplateBanner[]
  categorySections TemplateCategorySection[]
  categoryIcons    TemplateCategoryIcon[]
  customFonts      TemplateCustomFont[]
  heroSection      TemplateHeroSection?
  heroButtons      TemplateHeroButton[]
}

model TemplateHeroButton {
  id         String        @id @default(cuid())
  templateId String
  template   StoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  label         String
  text          String?
  actionType    String  @default("none")
  actionTarget  String?
  actionUrl     String?
  actionMessage String?
  order         Int     @default(0)

  @@index([templateId])
}

model TemplateService {
  id         String        @id @default(cuid())
  templateId String
  template   StoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  icon  String  @default("Sparkles")
  title String?
  desc  String?

  worksTitle String?
  worksDesc  String?

  order   Int     @default(0)
  enabled Boolean @default(true)

  works TemplateWork[]

  @@index([templateId])
}

model TemplateWork {
  id         String        @id @default(cuid())
  templateId String
  template   StoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  serviceId   String?
  service     TemplateService? @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  image       String?
  displayType String?          @default("ICON")
  title       String
  icon        String?
  category    String?
  link        String?
  order       Int              @default(0)

  @@index([templateId])
  @@index([serviceId])
}

model TemplateTestimonial {
  id         String        @id @default(cuid())
  templateId String
  template   StoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  name   String
  role   String?
  text   String
  rating Int     @default(5)
  order  Int     @default(0)

  @@index([templateId])
}

model TemplateBanner {
  id         String        @id @default(cuid())
  templateId String
  template   StoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  postion    String        @default("up")
  url        String
  order      Int           @default(0)

  @@index([templateId])
}

model TemplateCategorySection {
  id         String        @id @default(cuid())
  templateId String
  template   StoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  category String
  enabled  Boolean @default(true)
  order    Int     @default(0)

  @@index([templateId])
}

model TemplateCategoryIcon {
  id         String        @id @default(cuid())
  templateId String
  template   StoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  category String
  icon     String  @default("Package")
  image    String?

  @@unique([templateId, category])
  @@index([templateId])
}

model TemplateCustomFont {
  id         String        @id @default(cuid())
  templateId String
  template   StoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  name String
  url  String

  @@unique([templateId, name])
  @@index([templateId])
}

model PaymentLink {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  description String?
  storeId     String?
  userId      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store? @relation(fields: [storeId], references: [id], onDelete: Cascade)

  submissions PaymentLinkSubmission[]
}

model PaymentLinkSubmission {
  id            String            @id @default(cuid())
  paymentLinkId String
  payerName     String
  payerPhone    String
  payerEmail    String?
  payMethod     String
  status        PaymentLinkStatus @default(PENDING)

  cartId      String?  @unique
  tranRef     String?
  paymentUrl  String?
  respCode    String?
  respMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paymentLink PaymentLink @relation(fields: [paymentLinkId], references: [id], onDelete: Cascade)
}

enum PaymentLinkStatus {
  PENDING
  INITIATED
  PAID
  FAILED
  CANCELLED
}

model TemplateHeroSection {
  id         String        @id @default(cuid())
  templateId String        @unique
  template   StoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // section state
  enabled Boolean @default(true)
  visible Boolean @default(true)
  order   Int     @default(0)

  // content
  badgeText     String?
  badgeIcon     String?
  overline      String?
  title         String?
  highlightText String?
  subtitle      String?
  description   String?

  // trust / note
  trustText String?
  smallNote String?

  // buttons
  primaryButtonText   String?
  primaryButtonLink   String?
  primaryButtonIcon   String?
  primaryButtonTarget String? @default("_self")

  secondaryButtonText   String?
  secondaryButtonLink   String?
  secondaryButtonIcon   String?
  secondaryButtonTarget String? @default("_self")

  // optional extra CTA
  tertiaryButtonText   String?
  tertiaryButtonLink   String?
  tertiaryButtonIcon   String?
  tertiaryButtonTarget String? @default("_self")

  // media
  heroImage       String?
  heroImageAlt    String?
  heroImageMobile String?
  heroVideo       String?
  heroVideoPoster String?

  // background
  backgroundType         String? @default("COLOR") // COLOR | IMAGE | VIDEO | GRADIENT
  backgroundImage        String?
  backgroundImageMobile  String?
  backgroundVideo        String?
  backgroundColor        String?
  backgroundGradientFrom String?
  backgroundGradientTo   String?
  backgroundGradientVia  String?

  // overlay
  overlayEnabled Boolean @default(true)
  overlayColor   String?
  overlayOpacity Int     @default(35)

  // layout
  layout          String  @default("SPLIT") // CENTERED | SPLIT | IMAGE_LEFT | IMAGE_RIGHT | MINIMAL | FULLSCREEN
  contentAlign    String  @default("center") // left | center | right
  contentPosition String  @default("center") // start | center | end
  mediaPosition   String  @default("right") // left | right | top | bottom
  contentMaxWidth String?
  sectionHeight   String? @default("auto") // auto | sm | md | lg | xl | screen
  containerStyle  String? @default("boxed") // boxed | full
  verticalPadding String? @default("lg")

  // behavior
  showButtons    Boolean @default(true)
  showBadge      Boolean @default(true)
  showStats      Boolean @default(false)
  showFeatures   Boolean @default(false)
  showTrustItems Boolean @default(false)
  showScrollHint Boolean @default(false)

  // style flags
  roundedMedia   Boolean @default(true)
  glassEffect    Boolean @default(false)
  blurBackground Boolean @default(false)
  shadowMedia    Boolean @default(true)
  borderMedia    Boolean @default(false)

  // promo / campaign
  promoText   String?
  promoEndsAt DateTime?
  urgencyText String?

  // seo-ish/accessibility
  ariaLabel String?
  sectionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stats      TemplateHeroStat[]
  features   TemplateHeroFeature[]
  trustItems TemplateHeroTrustItem[]
  badges     TemplateHeroBadge[]
  socials    TemplateHeroSocialLink[]

  @@index([templateId])
}

model TemplateHeroStat {
  id     String              @id @default(cuid())
  heroId String
  hero   TemplateHeroSection @relation(fields: [heroId], references: [id], onDelete: Cascade)

  label   String
  value   String
  icon    String?
  order   Int     @default(0)
  enabled Boolean @default(true)

  @@index([heroId])
}

model TemplateHeroFeature {
  id     String              @id @default(cuid())
  heroId String
  hero   TemplateHeroSection @relation(fields: [heroId], references: [id], onDelete: Cascade)

  title   String
  desc    String?
  icon    String?
  image   String?
  link    String?
  order   Int     @default(0)
  enabled Boolean @default(true)

  @@index([heroId])
}

model TemplateHeroTrustItem {
  id     String              @id @default(cuid())
  heroId String
  hero   TemplateHeroSection @relation(fields: [heroId], references: [id], onDelete: Cascade)

  text    String
  icon    String?
  order   Int     @default(0)
  enabled Boolean @default(true)

  @@index([heroId])
}

model TemplateHeroBadge {
  id     String              @id @default(cuid())
  heroId String
  hero   TemplateHeroSection @relation(fields: [heroId], references: [id], onDelete: Cascade)

  text    String
  icon    String?
  color   String?
  order   Int     @default(0)
  enabled Boolean @default(true)

  @@index([heroId])
}

model TemplateHeroSocialLink {
  id     String              @id @default(cuid())
  heroId String
  hero   TemplateHeroSection @relation(fields: [heroId], references: [id], onDelete: Cascade)

  platform String
  label    String?
  url      String
  icon     String?
  order    Int     @default(0)
  enabled  Boolean @default(true)

  @@index([heroId])
}
